# ─── TeachHub Caddy Config ───────────────────────────────
# Without a domain: HTTP only on port 80
# With a domain: replace :80 with your domain for auto-HTTPS
#
# Example with domain:
#   teachhub.com {
#       reverse_proxy app:8080
#   }

teachhub.chickenkiller.com {
    handle /rtc* {
        reverse_proxy livekit:7880
    }
    handle {
        reverse_proxy app:8080
    }
}

:80 {
    reverse_proxy app:8080
}
