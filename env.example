# ─── TeachHub Production Environment ────────────────────
# Copy this to .env and fill in real values before deploying.
# The deploy.sh script generates this automatically.
# NEVER commit .env to git.

# Required — app will refuse to start without these
SESSION_SECRET=CHANGE_ME_random_32_char_string_here
ADMIN_PASS=CHANGE_ME_strong_admin_password
PLATFORM_PASS=CHANGE_ME_strong_platform_password
BASE_URL=http://YOUR_SERVER_IP
DB_PASSWORD=CHANGE_ME_strong_db_password
LIVEKIT_API_SECRET=CHANGE_ME_livekit_secret_32chars

# Optional
ADMIN_USER=admin
PLATFORM_USER=owner
PLATFORM_PATH=/ctrl-p-8x3kf
ANTHROPIC_API_KEY=
